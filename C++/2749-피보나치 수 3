#include <bits/stdc++.h>
using namespace std;

long long arr[1500050];
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    long long n;
    cin >> n;
    arr[0]=0;
    arr[1]=1;
    arr[2]=1;
    for (int i=3; i<=1500000; i++) {
        arr[i]=(arr[i-1]+arr[i-2])%1000000;
    }
    cout << arr[n%1500000];
}
